{
  "compilerOptions": {
    "typeRoots": ["./node_modules/@types"],
    "module": "esnext",
    "target": "esnext",
    "lib": ["es2020", "dom"],
    "noImplicitAny": true,
    "moduleResolution": "node",
    "strictNullChecks": true,
    "importHelpers": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["main.ts", "src/**/*.ts"]
}
